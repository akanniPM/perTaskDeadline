+describe('criterion #16 — thrown teardown error surfaces on pool error event', () => {
+  test('teardownCompleted is false and pool emits error when teardown throws', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 40,
+        gracePeriod: 40,
+        teardown: 'throwingTeardown',
+        terminateTimeout: 2000,
+      } as any)
+    )
+
+    const errors: Error[] = []
+    pool.on('error', (e: Error) => errors.push(e))
+
+    const err: any = await pool.run({}).then(
+      () => {
+        throw new Error('expected rejection')
+      },
+      (e) => e
+    )
+
+    expect(err.name).toBe('TaskTimeoutError')
+    expect(err.teardownAttempted).toBe(true)
+    expect(err.teardownCompleted).toBe(false)
+
+    // The thrown teardown error must surface on the pool 'error' event.
+    const deadline = Date.now() + 500
+    while (errors.length === 0 && Date.now() < deadline) {
+      await delay(25)
+    }
+    expect(errors.length).toBeGreaterThanOrEqual(1)
+    expect(errors[0]).toBeInstanceOf(Error)
+  })
+})
