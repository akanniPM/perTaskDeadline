--- /dev/null
+++ b/test.sh
@@ -0,0 +1,68 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+MODE=""
+OUTPUT_PATH=""
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --output_path)
+      OUTPUT_PATH="${2:-}"
+      shift 2
+      ;;
+    --output_path=*)
+      OUTPUT_PATH="${1#*=}"
+      shift
+      ;;
+    base|new)
+      MODE="$1"
+      shift
+      ;;
+    *)
+      echo "Unknown argument: $1" >&2
+      exit 1
+      ;;
+  esac
+done
+
+if [[ -z "$MODE" ]]; then
+  echo "Usage: $0 <base|new> [--output_path <path>]" >&2
+  exit 1
+fi
+
+node_modules/.bin/tsdown >/dev/null 2>&1 || true
+
+case "$MODE" in
+  base)
+    TARGET=(test/*.test.ts)
+    # --testTimeout: the suite has slow worker-spawn / child_process tests, so
+    # give them a wide ceiling.
+    # --isolate: the repo sets isolate:false, so all ~16 base files would share
+    # one reused test worker and the tinypool pools / socket listeners they spawn
+    # accumulate across the whole run, exhausting the heap and aborting with no
+    # JUnit. Isolating gives each file a fresh process so memory is reclaimed
+    # between files; this caps accumulation regardless of total size. Kept
+    # serial (--no-file-parallelism) so the fresh processes start one at a time.
+    # The heap bump is belt-and-suspenders headroom for any single slow file.
+    EXTRA=(--testTimeout=30000 --isolate)
+    export NODE_OPTIONS="${NODE_OPTIONS:-} --max-old-space-size=4096"
+    ;;
+  new)
+    TARGET=(test/new/*.test.ts)
+    # Keep the default (short) ceiling so the no-solution run -- whose breach
+    # tests never settle -- fails fast and still emits a report.
+    EXTRA=()
+    ;;
+esac
+
+REPORTER=()
+if [[ -n "$OUTPUT_PATH" ]]; then
+  mkdir -p "$(dirname "$OUTPUT_PATH")"
+  REPORTER=(--reporter=junit --outputFile="$OUTPUT_PATH")
+fi
+
+# Run test files one at a time. Each suite spins up its own tinypool worker
+# pools, so running files concurrently oversubscribes the CPU, which both slows
+# the run and flakes the upstream concurrency tests.
+exec node_modules/.bin/vitest run \
+  --no-file-parallelism \
+  "${EXTRA[@]}" "${REPORTER[@]}" "${TARGET[@]}"
