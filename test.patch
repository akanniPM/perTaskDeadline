--- /dev/null
+++ b/test/new/fixtures/reject-after.mjs
@@ -0,0 +1,9 @@
+import { setTimeout as delay } from 'node:timers/promises'
+
+// Runs for `time` ms, then rejects on its own. Used to exercise a task that
+// throws inside the grace window (the caller must see this error, not a
+// TaskTimeoutError, and the worker must not be hard-terminated).
+export default async function task({ time = 100 } = {}) {
+  await delay(time)
+  throw new Error('task rejected naturally')
+}
