index 0000000..ad752c6
--- /dev/null
+++ b/test/new/per-task-deadline.e6b18c.test.ts
@@ -0,0 +1,920 @@
+import { promisify } from 'node:util'
+import { dirname, resolve } from 'node:path'
+import { fileURLToPath } from 'node:url'
+import { MessageChannel } from 'node:worker_threads'
+import Tinypool from 'tinypool'
+
+const tinypoolModule: any = await import('tinypool')
+const TaskTimeoutError: any = tinypoolModule.TaskTimeoutError
+
+const __dirname = dirname(fileURLToPath(import.meta.url))
+const delay = promisify(setTimeout)
+
+const FIX = {
+  hang: resolve(__dirname, 'fixtures/hang.mjs'),
+  wedge: resolve(__dirname, 'fixtures/wedge.js'),
+  sleep: resolve(__dirname, 'fixtures/sleep-named.mjs'),
+  sleepShared: resolve(__dirname, '../fixtures/sleep.js'),
+  teardown: resolve(__dirname, '../fixtures/teardown.mjs'),
+}
+
+const pools: Tinypool[] = []
+afterEach(async () => {
+  // Race destroy against a short timeout so a deadlocked teardown cannot
+  // hang the test suite. Uses only the public API.
+  await Promise.allSettled(
+    pools.splice(0).map((p) =>
+      Promise.race([
+        p.destroy(),
+        new Promise<void>((r) => setTimeout(r, 500).unref?.()),
+      ])
+    )
+  )
+})
+function track<T extends Tinypool>(p: T): T {
+  pools.push(p)
+  return p
+}
+
+interface EventRecord {
+  name: string
+  payload: any
+  at: number
+}
+function recordEvents(
+  pool: Tinypool,
+  names: string[]
+): { log: EventRecord[]; counter: { n: number } } {
+  const log: EventRecord[] = []
+  const counter = { n: 0 }
+  for (const name of names) {
+    pool.on(name, (payload: any) => {
+      log.push({ name, payload, at: counter.n++ })
+    })
+  }
+  return { log, counter }
+}
+
+describe('TaskTimeoutError export', () => {
+  test('is an exported Error subclass', () => {
+    expect(typeof TaskTimeoutError).toBe('function')
+    const e = Object.create(TaskTimeoutError.prototype)
+    expect(e).toBeInstanceOf(Error)
+  })
+})
+
+describe('criterion #1 — taskTimeout with gracePeriod:0 rejects cleanly', () => {
+  test('rejects with TaskTimeoutError carrying configured values and false flags', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 80,
+        gracePeriod: 0,
+      } as any)
+    )
+
+    const err = await pool.run({}).then(
+      () => {
+        throw new Error('expected rejection')
+      },
+      (e) => e
+    )
+
+    expect(err).toBeInstanceOf(Error)
+    expect(err.name).toBe('TaskTimeoutError')
+    expect(err.taskTimeout).toBe(80)
+    expect(err.gracePeriod).toBe(0)
+    expect(err.graceEntered).toBe(false)
+    expect(err.teardownAttempted).toBe(false)
+  })
+
+  test('pool remains usable after a hard-terminated task', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 60,
+        gracePeriod: 0,
+      } as any)
+    )
+
+    await expect(pool.run({})).rejects.toBeInstanceOf(Error)
+
+    // A subsequent task (routed to a replacement worker) must resolve.
+    const result = await pool.run(
+      { time: 10, value: 'alive' },
+      { filename: FIX.sleep } as any
+    )
+    expect(result).toBe('alive')
+  })
+})
+
+describe('criterion #2 — task finishes within grace window resolves naturally', () => {
+  test('caller receives natural value; breach event fires once; hard-termination event does not fire', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.sleep,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 50,
+        gracePeriod: 800,
+      } as any)
+    )
+
+    const { log } = recordEvents(pool, ['taskTimeout', 'taskTimeoutTermination'])
+
+    const result = await pool.run({ time: 200, value: 'graceful' })
+    await delay(200)
+
+    expect(result).toBe('graceful')
+    expect(log.filter((e) => e.name === 'taskTimeout')).toHaveLength(1)
+    expect(log.filter((e) => e.name === 'taskTimeoutTermination')).toHaveLength(
+      0
+    )
+  })
+})
+
+describe('criterion #3 — task that never settles is hard-terminated after grace', () => {
+  test('rejects with TaskTimeoutError{graceEntered:true}; both events fire in order before rejection', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 50,
+        gracePeriod: 80,
+      } as any)
+    )
+
+    const { log } = recordEvents(pool, ['taskTimeout', 'taskTimeoutTermination'])
+
+    const err: any = await pool.run({}).then(
+      () => {
+        throw new Error('expected rejection')
+      },
+      (e) => e
+    )
+
+    expect(err.name).toBe('TaskTimeoutError')
+    expect(err.taskTimeout).toBe(50)
+    expect(err.gracePeriod).toBe(80)
+    expect(err.graceEntered).toBe(true)
+
+    const breach = log.filter((e) => e.name === 'taskTimeout')
+    const term = log.filter((e) => e.name === 'taskTimeoutTermination')
+    expect(breach).toHaveLength(1)
+    expect(term).toHaveLength(1)
+    expect(breach[0]!.at).toBeLessThan(term[0]!.at)
+  })
+
+  test('deadline-breach event payload exposes task and worker identification plus configured budgets', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 30,
+        gracePeriod: 40,
+      } as any)
+    )
+
+    let breach: any = null
+    let termination: any = null
+    pool.on('taskTimeout', (p: any) => (breach = p))
+    pool.on('taskTimeoutTermination', (p: any) => (termination = p))
+
+    await expect(pool.run({})).rejects.toBeInstanceOf(Error)
+
+    expect(breach).toBeTruthy()
+    expect(typeof breach.taskId).toBe('number')
+    expect(typeof breach.workerId).toBe('number')
+    expect(breach.taskTimeout).toBe(30)
+    expect(breach.gracePeriod).toBe(40)
+
+    expect(termination).toBeTruthy()
+    expect(termination.taskId).toBe(breach.taskId)
+    expect(termination.workerId).toBe(breach.workerId)
+    expect(typeof termination.teardownAttempted).toBe('boolean')
+  })
+})
+
+describe('criterion #4 — teardown runs on hard termination', () => {
+  test('teardown executes on the same worker before termination; error reports teardown flags', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 50,
+        gracePeriod: 50,
+        teardown: 'reportTeardown',
+        terminateTimeout: 2000,
+      } as any)
+    )
+
+    const { port1, port2 } = new MessageChannel()
+    const teardownObserved = new Promise<any>((resolve) =>
+      port2.on('message', resolve)
+    )
+
+    const err: any = await pool
+      .run({ port: port1 }, { transferList: [port1] })
+      .then(
+        () => {
+          throw new Error('expected rejection')
+        },
+        (e) => e
+      )
+
+    expect(err.name).toBe('TaskTimeoutError')
+    expect(err.teardownAttempted).toBe(true)
+    expect(err.teardownCompleted).toBe(true)
+
+    await expect(teardownObserved).resolves.toMatchObject({ type: 'teardown' })
+  })
+})
+
+describe('criterion #5 — teardown that hangs is bounded by terminateTimeout', () => {
+  test('rejection carries teardownCompleted:false; pool "error" channel receives a teardown failure', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 40,
+        gracePeriod: 40,
+        teardown: 'hangingTeardown',
+        terminateTimeout: 100,
+      } as any)
+    )
+
+    const errors: Error[] = []
+    pool.on('error', (e: Error) => errors.push(e))
+
+    const { port1, port2 } = new MessageChannel()
+    const teardownStarted = new Promise<any>((resolve) =>
+      port2.on('message', resolve)
+    )
+
+    const err: any = await pool
+      .run({ port: port1 }, { transferList: [port1] })
+      .then(
+        () => {
+          throw new Error('expected rejection')
+        },
+        (e) => e
+      )
+
+    expect(err.name).toBe('TaskTimeoutError')
+    expect(err.teardownAttempted).toBe(true)
+    expect(err.teardownCompleted).toBe(false)
+
+    await expect(teardownStarted).resolves.toMatchObject({
+      type: 'teardown-started',
+    })
+
+    // Allow up to terminateTimeout + buffer for the pool to surface the
+    // teardown failure on the 'error' channel. Poll so we don't over-wait.
+    const deadline = Date.now() + 500
+    while (errors.length === 0 && Date.now() < deadline) {
+      await delay(25)
+    }
+    expect(errors.length).toBeGreaterThanOrEqual(1)
+  })
+})
+
+describe('criterion #6 — queue wait time does not consume the deadline', () => {
+  test('task queued longer than taskTimeout still resolves if it runs to completion', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.sleep,
+        minThreads: 1,
+        maxThreads: 1,
+        concurrentTasksPerWorker: 1,
+      } as any)
+    )
+
+    // First task occupies the single worker for 300ms.
+    const blocker = pool.run({ time: 300, value: 'first' })
+    // Second task is enqueued immediately; it must wait ~300ms before dispatch,
+    // then run for only 20ms. With taskTimeout:120 applied to runtime-only, it must resolve.
+    const second = pool.run(
+      { time: 20, value: 'second' },
+      { taskTimeout: 120 } as any
+    )
+
+    await expect(blocker).resolves.toBe('first')
+    await expect(second).resolves.toBe('second')
+
+    // Queue wait must not have produced a deadline breach.
+    const p: any = pool
+    expect(p.taskTimeoutCount).toBe(0)
+    expect(p.taskTimeoutTerminationCount).toBe(0)
+  })
+})
+
+describe('criterion #7 — concurrentTasksPerWorker>1 isolation of timeout to one task', () => {
+  test('only the timed-out task rejects with TaskTimeoutError; sibling rejects with termination error; teardown fires once', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        concurrentTasksPerWorker: 2,
+        teardown: 'reportTeardown',
+        terminateTimeout: 2000,
+      } as any)
+    )
+
+    const { port1: pA, port2: pA2 } = new MessageChannel()
+    const { port1: pB, port2: pB2 } = new MessageChannel()
+    const teardownsA: any[] = []
+    const teardownsB: any[] = []
+    pA2.on('message', (m) => teardownsA.push(m))
+    pB2.on('message', (m) => teardownsB.push(m))
+
+    // Use a taskTimeout long enough that both tasks are observably
+    // in-flight on the same worker before the deadline fires.
+    const timedOut = pool.run(
+      { port: pA, name: 'A' },
+      { transferList: [pA], taskTimeout: 300, gracePeriod: 0 } as any
+    )
+    const sibling = pool.run(
+      { port: pB, name: 'B' },
+      { transferList: [pB] } as any
+    )
+
+    const [rA, rB] = await Promise.allSettled([timedOut, sibling])
+
+    expect(rA.status).toBe('rejected')
+    expect((rA as PromiseRejectedResult).reason.name).toBe('TaskTimeoutError')
+
+    expect(rB.status).toBe('rejected')
+    const bReason = (rB as PromiseRejectedResult).reason
+    expect(bReason).toBeInstanceOf(Error)
+    expect(bReason.name).not.toBe('TaskTimeoutError')
+
+    // Teardown must run exactly once for the worker, not once per sibling.
+    await delay(50)
+    const combined = [...teardownsA, ...teardownsB].filter(
+      (m) => m?.type === 'teardown'
+    )
+    expect(combined).toHaveLength(1)
+  })
+})
+
+describe('criterion #8 — external AbortSignal firing before deadline', () => {
+  test('caller sees AbortError; no deadline-breach or hard-termination event for the aborted task', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 5000,
+        gracePeriod: 0,
+      } as any)
+    )
+
+    const { log } = recordEvents(pool, ['taskTimeout', 'taskTimeoutTermination'])
+
+    const ac = new AbortController()
+    setTimeout(() => ac.abort(), 40)
+
+    const err: any = await pool.run({}, { signal: ac.signal }).then(
+      () => {
+        throw new Error('expected rejection')
+      },
+      (e) => e
+    )
+
+    expect(err.name).toBe('AbortError')
+    await delay(100)
+    expect(log).toHaveLength(0)
+
+    // An abort preceding the deadline must not register a breach.
+    const p: any = pool
+    expect(p.taskTimeoutCount).toBe(0)
+    expect(p.taskTimeoutTerminationCount).toBe(0)
+  })
+})
+
+describe('criterion #9 — AbortSignal during grace short-circuits grace', () => {
+  test('caller sees AbortError; hard-termination event does not fire on the deadline path', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 40,
+        gracePeriod: 5000,
+      } as any)
+    )
+
+    const { log } = recordEvents(pool, ['taskTimeout', 'taskTimeoutTermination'])
+
+    const ac = new AbortController()
+    // Allow the deadline to breach (grace begins), then abort.
+    setTimeout(() => ac.abort(), 150)
+
+    const err: any = await pool.run({}, { signal: ac.signal }).then(
+      () => {
+        throw new Error('expected rejection')
+      },
+      (e) => e
+    )
+
+    expect(err.name).toBe('AbortError')
+    await delay(100)
+
+    // The deadline must have breached (grace was entered) before the abort fired.
+    const p: any = pool
+    expect(p.taskTimeoutCount).toBe(1)
+
+    // Spec-mandated: hard-termination must NOT fire when abort short-circuits grace.
+    // The breach event may or may not have fired depending on whether the
+    // implementation emits it when grace is about to be short-circuited; we do
+    // not constrain that choice.
+    const term = log.filter((e) => e.name === 'taskTimeoutTermination')
+    expect(term).toHaveLength(0)
+  })
+})
+
+describe('criterion #10 — pool.destroy() during grace', () => {
+  test('caller rejects with TaskTimeoutError because the deadline had already breached', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 40,
+        gracePeriod: 5000,
+      } as any)
+    )
+
+    const pending = pool.run({})
+    await delay(150) // allow breach to fire; we are now in grace
+    const destroyed = pool.destroy()
+
+    const err: any = await pending.then(
+      () => {
+        throw new Error('expected rejection')
+      },
+      (e) => e
+    )
+
+    expect(err.name).toBe('TaskTimeoutError')
+    await destroyed
+  })
+})
+
+describe('criterion #11 — per-call overrides', () => {
+  test('per-call taskTimeout overrides pool default without affecting other concurrent calls', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.sleep,
+        minThreads: 2,
+        maxThreads: 2,
+        taskTimeout: 5000, // long pool default
+        gracePeriod: 0,
+      } as any)
+    )
+
+    // Task A: per-call override to a tight timeout so it rejects.
+    const a = pool.run(
+      { time: 400, value: 'A' },
+      { taskTimeout: 40, gracePeriod: 0 } as any
+    )
+    // Task B: uses pool default and finishes well within it.
+    const b = pool.run({ time: 50, value: 'B' })
+
+    const results = await Promise.allSettled([a, b])
+    expect(results[0].status).toBe('rejected')
+    expect(
+      (results[0] as PromiseRejectedResult).reason.name
+    ).toBe('TaskTimeoutError')
+    expect(
+      (results[0] as PromiseRejectedResult).reason.taskTimeout
+    ).toBe(40)
+    expect(results[1]).toMatchObject({ status: 'fulfilled', value: 'B' })
+  })
+})
+
+describe('criterion #12 — counters', () => {
+  test('breach and termination counters reflect observed behavior', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.sleep,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 0,
+        gracePeriod: 0,
+      } as any)
+    )
+
+    const p: any = pool
+    expect(p.taskTimeoutCount).toBe(0)
+    expect(p.taskTimeoutTerminationCount).toBe(0)
+
+    // Normal task — no timeout.
+    await pool.run({ time: 10, value: 'ok' })
+    expect(p.taskTimeoutCount).toBe(0)
+    expect(p.taskTimeoutTerminationCount).toBe(0)
+
+    // Task times out immediately (no grace) — both counters advance.
+    await expect(
+      pool.run(
+        { time: 400, value: 'late' },
+        { taskTimeout: 40, gracePeriod: 0 } as any
+      )
+    ).rejects.toBeInstanceOf(Error)
+    expect(p.taskTimeoutCount).toBe(1)
+    expect(p.taskTimeoutTerminationCount).toBe(1)
+
+    // Task breaches but settles during grace — only breach advances.
+    await pool.run(
+      { time: 120, value: 'grace' },
+      { taskTimeout: 40, gracePeriod: 1000 } as any
+    )
+    expect(p.taskTimeoutCount).toBe(2)
+    expect(p.taskTimeoutTerminationCount).toBe(1)
+  })
+
+  test('counters are read-only from user code', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.sleep,
+        minThreads: 1,
+        maxThreads: 1,
+      } as any)
+    )
+
+    const p: any = pool
+    const before1 = p.taskTimeoutCount
+    const before2 = p.taskTimeoutTerminationCount
+    expect(() => {
+      p.taskTimeoutCount = 9999
+    }).toThrow()
+    expect(() => {
+      p.taskTimeoutTerminationCount = 9999
+    }).toThrow()
+    expect(p.taskTimeoutCount).toBe(before1)
+    expect(p.taskTimeoutTerminationCount).toBe(before2)
+  })
+})
+
+describe.each(['worker_threads', 'child_process'] as const)(
+  'criterion #13 — runtime parity (%s)',
+  (runtime) => {
+    test('hard-termination produces TaskTimeoutError with configured taskTimeout', async () => {
+      const pool = track(
+        new Tinypool({
+          runtime,
+          filename: FIX.hang,
+          minThreads: 1,
+          maxThreads: 1,
+          taskTimeout: 60,
+          gracePeriod: 0,
+        } as any)
+      )
+
+      const err: any = await pool.run({}).then(
+        () => {
+          throw new Error('expected rejection')
+        },
+        (e) => e
+      )
+      expect(err.name).toBe('TaskTimeoutError')
+      expect(err.taskTimeout).toBe(60)
+    })
+
+    test('task that settles during grace resolves normally', async () => {
+      const pool = track(
