@@ -0,0 +1,696 @@
+import { fileURLToPath } from 'node:url'
+import { MessageChannel } from 'node:worker_threads'
+import { setTimeout as delay } from 'node:timers/promises'
+import { afterEach, describe, expect, it, test } from 'vitest'
+import Tinypool, { TaskTimeoutError, TinypoolEvent } from 'tinypool'
+import * as TinypoolNS from 'tinypool'
+
+const FIX = {
+  hang: fileURLToPath(new URL('./fixtures/hang.mjs', import.meta.url)),
+  sleep: fileURLToPath(new URL('./fixtures/sleep-named.mjs', import.meta.url)),
+  rejectAfter: fileURLToPath(
+    new URL('./fixtures/reject-after.mjs', import.meta.url)
+  ),
+}
+
+// ---------------------------------------------------------------------------
+// Test harness: every pool created through track()/makePool()/hangPool() is
+// destroyed after the test, and every fire-and-forget run() promise must be
+// caught so a teardown-time rejection never leaks.
+// ---------------------------------------------------------------------------
+const pools: Tinypool[] = []
+afterEach(async () => {
+  while (pools.length) {
+    const pool = pools.pop()!
+    try {
+      await pool.destroy()
+    } catch {
+      // pool may already be torn down by the test
+    }
+  }
+})
+
+function track(pool: Tinypool): Tinypool {
+  pools.push(pool)
+  return pool
+}
+
+// Quick pool over the sleep fixture; no workers spawned until a task runs.
+function makePool(opts: Record<string, unknown> = {}): Tinypool {
+  return track(
+    new Tinypool({
+      filename: FIX.sleep,
+      minThreads: 0,
+      maxThreads: 1,
+      ...opts,
+    } as any)
+  )
+}
+
+// Single-worker pool over the never-settling fixture.
+function hangPool(opts: Record<string, unknown> = {}): Tinypool {
+  return track(
+    new Tinypool({
+      filename: FIX.hang,
+      minThreads: 1,
+      maxThreads: 1,
+      ...opts,
+    } as any)
+  )
+}
+
+interface CapturedEvent {
+  name: string
+  payload: any
+}
+
+function capture(pool: Tinypool): CapturedEvent[] {
+  const events: CapturedEvent[] = []
+  for (const name of Object.values(TinypoolEvent)) {
+    pool.on(name, (payload: any) => events.push({ name, payload }))
+  }
+  return events
+}
+
+async function rejection(promise: Promise<unknown>): Promise<any> {
+  return promise.then(
+    () => {
+      throw new Error('expected the task to reject, but it resolved')
+    },
+    (err) => err
+  )
+}
+
+// ===========================================================================
+
+describe('public surface', () => {
+  it('exports TaskTimeoutError as a constructor', () => {
+    expect(typeof TaskTimeoutError).toBe('function')
+    const err = new TaskTimeoutError({
+      taskTimeout: 10,
+      gracePeriod: 0,
+      graceEntered: false,
+      teardownAttempted: false,
+      teardownCompleted: false,
+    })
+    expect(err).toBeInstanceOf(Error)
+    expect(err.name).toBe('TaskTimeoutError')
+  })
+
+  it('TaskTimeoutError carries a stable error code', () => {
+    const err = new TaskTimeoutError({
+      taskTimeout: 10,
+      gracePeriod: 5,
+      graceEntered: true,
+      teardownAttempted: false,
+      teardownCompleted: false,
+    })
+    expect(err.code).toBe('ETASKTIMEOUT')
+  })
+
+  it('TaskTimeoutError message reflects the timeout', () => {
+    const err = new TaskTimeoutError({
+      taskTimeout: 250,
+      gracePeriod: 0,
+      graceEntered: false,
+      teardownAttempted: false,
+      teardownCompleted: false,
+    })
+    // The spec only requires the message to include the timeout value; it does
+    // not dictate the surrounding format (e.g. a "ms" suffix), so assert on the
+    // value alone to keep the contract implementation-agnostic.
+    expect(err.message).toContain('250')
+  })
+
+  it('exports the TinypoolEvent name table', () => {
+    expect(TinypoolEvent).toMatchObject({
+      TaskTimeout: 'taskTimeout',
+      TaskTimeoutGrace: 'taskTimeoutGrace',
+      TaskTimeoutTermination: 'taskTimeoutTermination',
+    })
+  })
+
+  it('TaskTimeoutError is reachable via the namespace import', () => {
+    expect(typeof TinypoolNS.TaskTimeoutError).toBe('function')
+    expect(TinypoolNS.TaskTimeoutError).toBe(TaskTimeoutError)
+  })
+
+  it('a pool exposes the deadline counters, all starting at zero', () => {
+    const pool = makePool()
+    expect(pool.taskTimeoutCount).toBe(0)
+    expect(pool.taskTimeoutGraceCount).toBe(0)
+    expect(pool.taskTimeoutTerminationCount).toBe(0)
+  })
+
+  it('deadlineStats starts as an all-zero snapshot', () => {
+    const pool = makePool()
+    expect(pool.deadlineStats).toEqual({
+      timeouts: 0,
+      graceEntries: 0,
+      terminations: 0,
+    })
+  })
+})
+
+describe('option validation: taskTimeout', () => {
+  test.each([-1, -0.5, NaN, '500', {}, true, [] as any])(
+    'construction throws TypeError for taskTimeout=%p',
+    (bad) => {
+      expect(
+        () => new Tinypool({ filename: FIX.sleep, taskTimeout: bad as any })
+      ).toThrow(TypeError)
+    }
+  )
+
+  test.each([10, 1000, 0, Infinity, undefined, null as any])(
+    'construction accepts taskTimeout=%p',
+    (ok) => {
+      const pool = makePool({ taskTimeout: ok })
+      expect(pool.deadlineStats).toEqual({
+        timeouts: 0,
+        graceEntries: 0,
+        terminations: 0,
+      })
+    }
+  )
+})
+
+describe('option validation: gracePeriod', () => {
+  test.each([-1, -10, NaN, Infinity, '0', {}, true])(
+    'construction throws TypeError for gracePeriod=%p',
+    (bad) => {
+      expect(
+        () => new Tinypool({ filename: FIX.sleep, gracePeriod: bad as any })
+      ).toThrow(TypeError)
+    }
+  )
+
+  test.each([0, 50, 1000, undefined, null as any])(
+    'construction accepts gracePeriod=%p',
+    (ok) => {
+      const pool = makePool({ gracePeriod: ok })
+      expect(pool.deadlineStats).toEqual({
+        timeouts: 0,
+        graceEntries: 0,
+        terminations: 0,
+      })
+    }
+  )
+})
+
+describe('option validation: per-call', () => {
+  test.each([-1, NaN, '5', {}])(
+    'run() throws TypeError for taskTimeout=%p',
+    (bad) => {
+      const pool = makePool()
+      expect(() => pool.run({}, { taskTimeout: bad as any })).toThrow(TypeError)
+    }
+  )
+
+  test.each([-1, NaN, Infinity, 'x'])(
+    'run() throws TypeError for gracePeriod=%p',
+    (bad) => {
+      const pool = makePool()
+      expect(() => pool.run({}, { gracePeriod: bad as any })).toThrow(TypeError)
+    }
+  )
+
+  it('valid per-call options do not throw synchronously', () => {
+    const pool = makePool()
+    expect(() => {
+      const p = pool.run({ time: 1 }, { taskTimeout: 1000 })
+      p.catch(() => {})
+    }).not.toThrow()
+    expect(pool.deadlineStats).toEqual({
+      timeouts: 0,
+      graceEntries: 0,
+      terminations: 0,
+    })
+  })
+
+  it('a TypeError message names the offending field', () => {
+    const pool = makePool()
+    expect(() => pool.run({}, { taskTimeout: -1 as any })).toThrow(
+      /taskTimeout/
+    )
+  })
+
+  it('a gracePeriod TypeError message names the offending field', () => {
+    const pool = makePool()
+    expect(() => pool.run({}, { gracePeriod: -1 as any })).toThrow(
+      /gracePeriod/
+    )
+  })
+
+  it('per-call Infinity/null taskTimeout and null gracePeriod are accepted', async () => {
+    // Pool default would deadline an 80ms task at 30ms; each per-call disable
+    // form must override it so the task completes without a breach.
+    const pool = makePool({ taskTimeout: 30 })
+    await expect(
+      pool.run({ time: 80, value: 'inf' }, { taskTimeout: Infinity })
+    ).resolves.toBe('inf')
+    await expect(
+      pool.run({ time: 80, value: 'nul' }, { taskTimeout: null as any })
+    ).resolves.toBe('nul')
+    await expect(
+      pool.run({ time: 80, value: 'g' }, { taskTimeout: 0, gracePeriod: null as any })
+    ).resolves.toBe('g')
+    expect(pool.taskTimeoutCount).toBe(0)
+  })
+})
+
+describe('disable sentinels and defaults', () => {
+  it('a pool with no taskTimeout runs tasks to completion', async () => {
+    const pool = makePool()
+    await expect(pool.run({ time: 20, value: 'done' })).resolves.toBe('done')
+    expect(pool.deadlineStats).toEqual({
+      timeouts: 0,
+      graceEntries: 0,
+      terminations: 0,
+    })
+  })
+
+  it('taskTimeout:0 disables the deadline', async () => {
+    const pool = makePool({ taskTimeout: 0 })
+    await expect(pool.run({ time: 30, value: 'ok' })).resolves.toBe('ok')
+    expect(pool.taskTimeoutCount).toBe(0)
+  })
+
+  it('taskTimeout:Infinity disables the deadline', async () => {
+    const pool = makePool({ taskTimeout: Infinity })
+    await expect(pool.run({ time: 30, value: 'ok' })).resolves.toBe('ok')
+    expect(pool.taskTimeoutCount).toBe(0)
+  })
+
+  it('an omitted per-call deadline inherits the pool default', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const err = await rejection(pool.run({}))
+    expect(err.name).toBe('TaskTimeoutError')
+  })
+
+  it('per-call taskTimeout:0 opts a single task out of the pool default', async () => {
+    const pool = makePool({ taskTimeout: 30 })
+    await expect(
+      pool.run({ time: 90, value: 'survived' }, { taskTimeout: 0 })
+    ).resolves.toBe('survived')
+    expect(pool.taskTimeoutTerminationCount).toBe(0)
+  })
+})
+
+describe('deadline resolution precedence', () => {
+  it('a per-call taskTimeout overrides the pool default', async () => {
+    const pool = hangPool({ taskTimeout: 5000, gracePeriod: 0 })
+    const events = capture(pool)
+    const err = await rejection(pool.run({}, { taskTimeout: 40 }))
+    expect(err.name).toBe('TaskTimeoutError')
+    const fired = events.find((e) => e.name === TinypoolEvent.TaskTimeout)
+    expect(fired?.payload.taskTimeout).toBe(40)
+  })
+
+  it('a per-call gracePeriod overrides the pool default', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 5000 })
+    const events = capture(pool)
+    await rejection(pool.run({}, { gracePeriod: 30 }))
+    const grace = events.find((e) => e.name === TinypoolEvent.TaskTimeoutGrace)
+    expect(grace?.payload.gracePeriod).toBe(30)
+  })
+
+  it('an omitted per-call gracePeriod uses the pool default', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 30 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    const grace = events.find((e) => e.name === TinypoolEvent.TaskTimeoutGrace)
+    expect(grace?.payload.gracePeriod).toBe(30)
+  })
+
+  it('per-call gracePeriod:0 suppresses a pool-level grace window', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 200 })
+    const events = capture(pool)
+    const err = await rejection(pool.run({}, { gracePeriod: 0 }))
+    expect(err.graceEntered).toBe(false)
+    expect(events.some((e) => e.name === TinypoolEvent.TaskTimeoutGrace)).toBe(
+      false
+    )
+  })
+})
+
+describe('TaskTimeoutError on a breach', () => {
+  it('the rejection is a TaskTimeoutError with the deadline code', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const err = await rejection(pool.run({}))
+    expect(err).toBeInstanceOf(TaskTimeoutError)
+    expect(err.code).toBe('ETASKTIMEOUT')
+  })
+
+  it('gracePeriod:0 yields graceEntered:false', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const err = await rejection(pool.run({}))
+    expect(err.graceEntered).toBe(false)
+  })
+
+  it('gracePeriod>0 yields graceEntered:true', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 40 })
+    const err = await rejection(pool.run({}))
+    expect(err.graceEntered).toBe(true)
+  })
+
+  it('the error echoes the configured timing budget', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 25 })
+    const err = await rejection(pool.run({}))
+    expect(err.taskTimeout).toBe(40)
+    expect(err.gracePeriod).toBe(25)
+  })
+
+  it('with no teardown configured, teardown flags are false', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const err = await rejection(pool.run({}))
+    expect(err.teardownAttempted).toBe(false)
+    expect(err.teardownCompleted).toBe(false)
+  })
+})
+
+describe('deadline events', () => {
+  it('a taskTimeout event carries the expected shape', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    const fired = events.find((e) => e.name === TinypoolEvent.TaskTimeout)
+    expect(fired?.payload).toMatchObject({
+      taskTimeout: 40,
+      gracePeriod: 0,
+    })
+    expect(typeof fired?.payload.taskId).toBe('number')
+    expect(typeof fired?.payload.workerId).toBe('number')
+  })
+
+  it('no taskTimeoutGrace event is emitted when gracePeriod is 0', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    expect(events.some((e) => e.name === TinypoolEvent.TaskTimeoutGrace)).toBe(
+      false
+    )
+  })
+
+  it('a taskTimeoutGrace event is emitted when gracePeriod>0', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 40 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    expect(events.some((e) => e.name === TinypoolEvent.TaskTimeoutGrace)).toBe(
+      true
+    )
+  })
+
+  it('a taskTimeoutTermination event carries the full payload', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 30 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    const term = events.find(
+      (e) => e.name === TinypoolEvent.TaskTimeoutTermination
+    )
+    expect(term?.payload).toMatchObject({
+      taskTimeout: 40,
+      gracePeriod: 30,
+      graceEntered: true,
+      teardownAttempted: false,
+      teardownCompleted: false,
+    })
+    expect(typeof term?.payload.taskId).toBe('number')
+    expect(typeof term?.payload.workerId).toBe('number')
+  })
+
+  it('events fire in order: timeout, grace, termination', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 30 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    expect(events.map((e) => e.name)).toEqual([
+      TinypoolEvent.TaskTimeout,
+      TinypoolEvent.TaskTimeoutGrace,
+      TinypoolEvent.TaskTimeoutTermination,
+    ])
+  })
+
+  it('with gracePeriod:0 only timeout and termination fire, in order', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    expect(events.map((e) => e.name)).toEqual([
+      TinypoolEvent.TaskTimeout,
+      TinypoolEvent.TaskTimeoutTermination,
+    ])
+  })
+
+  it('no deadline events fire when a task finishes in time', async () => {
+    const pool = makePool({ taskTimeout: 500 })
+    const events = capture(pool)
+    await expect(pool.run({ time: 20, value: 'ok' })).resolves.toBe('ok')
+    expect(events).toHaveLength(0)
+  })
+
+  it('the termination payload taskId matches the timeout payload taskId', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const events = capture(pool)
+    await rejection(pool.run({}))
+    const fired = events.find((e) => e.name === TinypoolEvent.TaskTimeout)
+    const term = events.find(
+      (e) => e.name === TinypoolEvent.TaskTimeoutTermination
+    )
+    expect(term?.payload.taskId).toBe(fired?.payload.taskId)
+  })
+})
+
+describe('counters and deadlineStats', () => {
+  it('taskTimeoutCount increments on a breach', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    await rejection(pool.run({}))
+    expect(pool.taskTimeoutCount).toBe(1)
+  })
+
+  it('the grace counter only moves when a grace window opens', async () => {
+    const noGrace = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    await rejection(noGrace.run({}))
+    expect(noGrace.taskTimeoutGraceCount).toBe(0)
+
+    const withGrace = hangPool({ taskTimeout: 40, gracePeriod: 30 })
+    await rejection(withGrace.run({}))
+    expect(withGrace.taskTimeoutGraceCount).toBe(1)
+  })
+
+  it('taskTimeoutTerminationCount increments on a hard termination', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    await rejection(pool.run({}))
+    expect(pool.taskTimeoutTerminationCount).toBe(1)
+  })
+
+  it('counters remain zero when nothing breaches', async () => {
+    const pool = makePool({ taskTimeout: 500 })
+    await pool.run({ time: 10, value: 'ok' })
+    expect(pool.deadlineStats).toEqual({
+      timeouts: 0,
+      graceEntries: 0,
+      terminations: 0,
+    })
+  })
+
+  it('deadlineStats reflects the counters after a breach', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 30 })
+    await rejection(pool.run({}))
+    expect(pool.deadlineStats).toEqual({
+      timeouts: 1,
+      graceEntries: 1,
+      terminations: 1,
+    })
+  })
+
+  it('deadlineStats returns a copy that cannot mutate pool state', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    await rejection(pool.run({}))
+    const snap = pool.deadlineStats
+    snap.timeouts = 999
+    expect(pool.deadlineStats.timeouts).toBe(1)
+  })
+
+  it('repeated breaches accumulate', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    await rejection(pool.run({}))
+    await rejection(pool.run({}))
+    expect(pool.taskTimeoutCount).toBe(2)
+    expect(pool.taskTimeoutTerminationCount).toBe(2)
+  })
+})
+
+describe('core deadline behavior', () => {
+  it('gracePeriod:0 hard-terminates as soon as the timeout elapses', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 0 })
+    const err = await rejection(pool.run({}))
+    expect(err.name).toBe('TaskTimeoutError')
+    expect(err.graceEntered).toBe(false)
+    expect(pool.taskTimeoutTerminationCount).toBe(1)
+  })
+
+  it('a task that settles inside the grace window resolves naturally', async () => {
+    const pool = makePool({ taskTimeout: 40, gracePeriod: 200, maxThreads: 1 })
+    await expect(pool.run({ time: 90, value: 'made-it' })).resolves.toBe(
+      'made-it'
+    )
+    expect(pool.taskTimeoutTerminationCount).toBe(0)
+  })
+
+  it('a task that rejects inside the grace window propagates its own error', async () => {
+    // Breaches at 40ms (grace runs to 340ms); the task throws on its own at
+    // ~90ms, inside the window, so the caller sees that error -- not a
+    // TaskTimeoutError -- and the worker is never hard-terminated.
+    const pool = track(
+      new Tinypool({
+        filename: FIX.rejectAfter,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 40,
+        gracePeriod: 300,
+      } as any)
+    )
+    const err = await rejection(pool.run({ time: 90 }))
+    expect(err.name).not.toBe('TaskTimeoutError')
+    expect(/rejected naturally/.test(err.message)).toBe(true)
+    expect(pool.taskTimeoutTerminationCount).toBe(0)
+  })
+
+  it('a task that never settles is terminated after the grace window', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 40 })
+    const err = await rejection(pool.run({}))
+    expect(err.graceEntered).toBe(true)
+    expect(pool.taskTimeoutTerminationCount).toBe(1)
+  })
+
+  it('a teardown hook runs on hard termination', async () => {
+    const pool = hangPool({
+      taskTimeout: 40,
+      gracePeriod: 20,
+      teardown: 'reportTeardown',
+    })
+    const { port1, port2 } = new MessageChannel()
+    const seen = new Promise<any>((resolve) => port2.once('message', resolve))
+    const err = await rejection(
+      pool.run({ port: port1 }, { transferList: [port1] })
+    )
+    expect(err.teardownAttempted).toBe(true)
+    expect(err.teardownCompleted).toBe(true)
+    await expect(seen).resolves.toMatchObject({ type: 'teardown' })
+    port2.close()
+  })
+
+  it('a teardown that hangs is bounded by terminateTimeout', async () => {
+    // minThreads:0 so no replacement worker is spun up after the termination —
+    // a pool-level hanging teardown would otherwise block afterEach's destroy.
+    const pool = hangPool({
+      minThreads: 0,
+      taskTimeout: 40,
+      gracePeriod: 40,
+      teardown: 'hangingTeardown',
+      terminateTimeout: 100,
+    })
+    const errors: Error[] = []
+    pool.on('error', (e: Error) => errors.push(e))
+    const err = await rejection(pool.run({}))
+    expect(err.teardownAttempted).toBe(true)
+    expect(err.teardownCompleted).toBe(false)
+    const deadline = Date.now() + 500
+    while (errors.length === 0 && Date.now() < deadline) {
+      await delay(25)
+    }
+    expect(errors.length).toBeGreaterThanOrEqual(1)
+  })
+
+  it('a teardown that throws surfaces on the pool error channel', async () => {
+    const pool = hangPool({
+      taskTimeout: 40,
+      gracePeriod: 20,
+      teardown: 'throwingTeardown',
+    })
+    const errors: Error[] = []
+    pool.on('error', (e: Error) => errors.push(e))
+    const err = await rejection(pool.run({}))
+    expect(err.teardownAttempted).toBe(true)
+    expect(err.teardownCompleted).toBe(false)
+    const deadline = Date.now() + 500
+    while (errors.length === 0 && Date.now() < deadline) {
+      await delay(25)
+    }
+    expect(errors.some((e) => /intentionally/.test(e.message))).toBe(true)
+  })
+
+  it('an AbortSignal firing before the deadline wins, with no timeout event', async () => {
+    const pool = hangPool({ taskTimeout: 500, gracePeriod: 0 })
+    const events = capture(pool)
+    const ac = new AbortController()
+    const p = rejection(pool.run({}, { signal: ac.signal }))
+    ac.abort()
+    const err = await p
+    expect(err.name).toBe('AbortError')
+    await delay(60)
+    expect(events).toHaveLength(0)
+    expect(pool.taskTimeoutCount).toBe(0)
+  })
+
+  it('pool.destroy() during the grace window settles the task', async () => {
+    const pool = hangPool({ taskTimeout: 40, gracePeriod: 2000 })
+    const p = rejection(pool.run({}))
+    await delay(90)
+    await pool.destroy()
+    const err = await p
+    expect(err).toBeInstanceOf(Error)
+    expect(err.name).toBe('TaskTimeoutError')
+  })
+
+  it('with concurrentTasksPerWorker>1 only the offending slot is charged a termination', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        concurrentTasksPerWorker: 2,
+        taskTimeout: 40,
+        gracePeriod: 0,
+      } as any)
+    )
+    const a = rejection(pool.run({ marker: 'a' }))
+    const b = rejection(pool.run({ marker: 'b' }))
+    const [ea, eb] = await Promise.all([a, b])
+    const names = [ea.name, eb.name]
+    expect(names).toContain('TaskTimeoutError')
+    expect(pool.taskTimeoutTerminationCount).toBe(1)
+  })
+
+  it('the pool keeps serving tasks after a termination', async () => {
+    // sleep fixture: the first task sleeps past its deadline and is terminated;
+    // the second opts out of the deadline and completes on a fresh worker.
+    const pool = makePool({
+      taskTimeout: 40,
+      gracePeriod: 0,
+      minThreads: 1,
+      maxThreads: 1,
+    })
+    const first = await rejection(pool.run({ time: 200 }))
+    expect(first.name).toBe('TaskTimeoutError')
+    await expect(
+      pool.run({ time: 10, value: 'ok' }, { taskTimeout: 0 })
+    ).resolves.toBe('ok')
+    expect(pool.taskTimeoutTerminationCount).toBe(1)
+  })
+
+  it('queue wait does not consume the deadline budget', async () => {
+    // Single worker: the second task waits ~200ms in the queue behind the
+    // first, far longer than its 100ms taskTimeout, but only runs for 20ms.
+    // The budget starts at dispatch, so it must resolve without a breach.
+    const pool = makePool({ minThreads: 1, maxThreads: 1 })
+    const first = pool.run({ time: 200, value: 'first' })
+    const second = pool.run(
+      { time: 20, value: 'second' },
+      { taskTimeout: 100 }
+    )
+    await expect(first).resolves.toBe('first')
+    await expect(second).resolves.toBe('second')
+    expect(pool.taskTimeoutCount).toBe(0)
+    expect(pool.taskTimeoutTerminationCount).toBe(0)
+  })
+})
