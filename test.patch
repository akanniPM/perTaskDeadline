+describe('criterion #18 — event payloads carry per-call override values, not pool defaults', () => {
+  test('breach and termination events report the per-call taskTimeout and gracePeriod', async () => {
+    // Pool defaults are intentionally very different from the per-call override
+    // so any impl that hardcodes pool config in the payload will be caught.
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 9999,
+        gracePeriod: 9999,
+      } as any)
+    )
+
+    let breach: any = null
+    let termination: any = null
+    pool.on('taskTimeout', (p: any) => (breach = p))
+    pool.on('taskTimeoutTermination', (p: any) => (termination = p))
+
+    await expect(
+      pool.run({}, { taskTimeout: 50, gracePeriod: 60 } as any)
+    ).rejects.toBeInstanceOf(Error)
+
+    expect(breach).toBeTruthy()
+    expect(breach.taskTimeout).toBe(50)
+    expect(breach.gracePeriod).toBe(60)
+
+    expect(termination).toBeTruthy()
+    expect(termination.taskTimeout).toBe(50)
+    expect(termination.gracePeriod).toBe(60)
+  })
+
+  test('TaskTimeoutError carries per-call override values, not pool defaults', async () => {
+    const pool = track(
+      new Tinypool({
+        filename: FIX.hang,
+        minThreads: 1,
+        maxThreads: 1,
+        taskTimeout: 9999,
