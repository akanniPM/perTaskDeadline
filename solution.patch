@@ -0,0 +1,37 @@
+// Error raised when a task exceeds its configured deadline and the pool gives
+// up waiting for it. Carries the timing budget that was in force plus a record
+// of what the pool did about it (whether it entered the grace window, whether a
+// teardown hook ran, and whether that teardown finished in time).
+
+export interface TaskTimeoutErrorFields {
+  taskTimeout: number
+  gracePeriod: number
+  graceEntered: boolean
+  teardownAttempted: boolean
+  teardownCompleted: boolean
+}
+
+export class TaskTimeoutError extends Error {
+  // Stable, machine-readable discriminator. Lets callers branch on the error
+  // without relying on `instanceof` across module/realm boundaries.
+  readonly code = 'ETASKTIMEOUT'
+
+  taskTimeout: number
+  gracePeriod: number
+  graceEntered: boolean
+  teardownAttempted: boolean
+  teardownCompleted: boolean
+
+  constructor(fields: TaskTimeoutErrorFields) {
+    super(`Task timed out after ${fields.taskTimeout}ms`)
+    this.taskTimeout = fields.taskTimeout
+    this.gracePeriod = fields.gracePeriod
+    this.graceEntered = fields.graceEntered
+    this.teardownAttempted = fields.teardownAttempted
+    this.teardownCompleted = fields.teardownCompleted
+  }
+
+  get name(): string {
+    return 'TaskTimeoutError'
+  }
+}
