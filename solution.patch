+++ b/src/deadline/events.ts
@@ -0,0 +1,77 @@
+// Event names the pool emits over the lifetime of a deadline, plus the shapes
+// of their payloads and small builders so every emit site produces a consistent
+// object.
+
+export const TinypoolEvent = {
+  // taskTimeout has elapsed; the pool is about to act on it.
+  TaskTimeout: 'taskTimeout',
+  // The grace window opened (only emitted when gracePeriod > 0).
+  TaskTimeoutGrace: 'taskTimeoutGrace',
+  // The worker was hard-terminated to reclaim the slot.
+  TaskTimeoutTermination: 'taskTimeoutTermination',
+} as const
+
+export type TinypoolEventName =
+  (typeof TinypoolEvent)[keyof typeof TinypoolEvent]
+
+export interface TaskTimeoutPayload {
+  taskId: number
+  workerId: number
+  taskTimeout: number
+  gracePeriod: number
+}
+
+export interface TaskTimeoutGracePayload {
+  taskId: number
+  workerId: number
+  taskTimeout: number
+  gracePeriod: number
+}
+
+export interface TaskTimeoutTerminationPayload {
+  taskId: number
+  workerId: number
+  taskTimeout: number
+  gracePeriod: number
+  graceEntered: boolean
+  teardownAttempted: boolean
+  teardownCompleted: boolean
+}
+
+export function buildTimeoutPayload(
+  taskId: number,
+  workerId: number,
+  taskTimeout: number,
+  gracePeriod: number
+): TaskTimeoutPayload {
+  return { taskId, workerId, taskTimeout, gracePeriod }
+}
+
+export function buildGracePayload(
+  taskId: number,
+  workerId: number,
+  taskTimeout: number,
+  gracePeriod: number
+): TaskTimeoutGracePayload {
+  return { taskId, workerId, taskTimeout, gracePeriod }
+}
+
+export function buildTerminationPayload(
+  taskId: number,
+  workerId: number,
+  taskTimeout: number,
+  gracePeriod: number,
+  graceEntered: boolean,
+  teardownAttempted: boolean,
+  teardownCompleted: boolean
+): TaskTimeoutTerminationPayload {
+  return {
+    taskId,
+    workerId,
+    taskTimeout,
+    gracePeriod,
+    graceEntered,
+    teardownAttempted,
+    teardownCompleted,
+  }
+}
