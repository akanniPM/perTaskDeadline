@@ -0,0 +1,35 @@
+// Running tallies of deadline activity for a pool. Counters only ever move
+// forward; `snapshot()` hands back a plain copy so callers can read a coherent
+// set of values without being able to mutate the pool's internal state.
+
+export interface DeadlineStats {
+  timeouts: number
+  graceEntries: number
+  terminations: number
+}
+
+export class DeadlineMetrics {
+  timeouts = 0
+  graceEntries = 0
+  terminations = 0
+
+  recordTimeout(): void {
+    this.timeouts++
+  }
+
+  recordGraceEntry(): void {
+    this.graceEntries++
+  }
+
+  recordTermination(): void {
+    this.terminations++
+  }
+
+  snapshot(): DeadlineStats {
+    return {
+      timeouts: this.timeouts,
+      graceEntries: this.graceEntries,
+      terminations: this.terminations,
+    }
+  }
+}
diff --git a/src/deadline/options.ts b/src/deadline/options.ts
new file mode 100644
index 0000000..2095c63
--- /dev/null
+++ b/src/deadline/options.ts
@@ -0,0 +1,51 @@
+// Validation and normalization for the deadline options (`taskTimeout` and
+// `gracePeriod`). Bad values fail loudly with a TypeError at the point of
+// configuration rather than being silently ignored, so a typo like
+// `taskTimeout: -1` or `taskTimeout: '500'` is caught immediately.
+//
+// Accepted "disable" forms are deliberately permissive: leaving an option out,
+// passing `undefined`/`null`, or passing `0` all mean "no deadline". For
+// `taskTimeout`, `Infinity` is also treated as "no deadline". Everything else
+// must be a real, non-negative number.
+
+import { isNumber } from '../utils'
+
+function reject(field: string, value: unknown, reason: string): never {
+  const shown =
+    typeof value === 'string' ? JSON.stringify(value) : String(value)
+  throw new TypeError(`${field} ${reason} (received ${typeof value}: ${shown})`)
+}
+
+// Returns the effective timeout in ms, or `undefined` when there is no
+// deadline. Throws TypeError on a value that is neither a valid duration nor a
+// recognized "disable" form.
+export function parseTaskTimeout(value: unknown): number | undefined {
+  if (value === undefined || value === null) return undefined
+  if (!isNumber(value)) reject('taskTimeout', value, 'must be a number')
+  if (Number.isNaN(value)) reject('taskTimeout', value, 'must not be NaN')
+  if (value < 0) reject('taskTimeout', value, 'must not be negative')
+  // 0 and Infinity both mean "run without a deadline".
+  if (value === 0 || !Number.isFinite(value)) return undefined
+  return value
+}
+
+// Returns the grace window in ms (>= 0). Unlike taskTimeout, the grace window
+// must be finite. Throws TypeError on an invalid value.
+export function parseGracePeriod(value: unknown): number {
+  if (value === undefined || value === null) return 0
+  if (!isNumber(value)) reject('gracePeriod', value, 'must be a number')
+  if (Number.isNaN(value)) reject('gracePeriod', value, 'must not be NaN')
+  if (!Number.isFinite(value)) reject('gracePeriod', value, 'must be finite')
+  if (value < 0) reject('gracePeriod', value, 'must not be negative')
+  return value
+}
+
+// Throws if either option is invalid; used to validate a whole options bag up
+// front (pool construction or a per-call override) without keeping the result.
+export function validateDeadlineOptions(opts: {
+  taskTimeout?: unknown
+  gracePeriod?: unknown
+}): void {
+  if ('taskTimeout' in opts) parseTaskTimeout(opts.taskTimeout)
+  if ('gracePeriod' in opts) parseGracePeriod(opts.gracePeriod)
+}
diff --git a/src/deadline/resolve.ts b/src/deadline/resolve.ts
new file mode 100644
index 0000000..9f1216c
--- /dev/null
+++ b/src/deadline/resolve.ts
@@ -0,0 +1,42 @@
+// Works out the deadline that actually applies to a single task by layering a
+// per-call override on top of the pool-level defaults.
+//
+// Precedence, evaluated per option independently:
+//   1. If the caller passed the option to `run()` (the key is present), that
+//      value wins — even if it is `0`/`undefined`, which is how a caller opts a
+//      single task out of a pool-wide deadline.
+//   2. Otherwise the pool default applies.
+//
+// The presence check (key-in-options) matters: an explicit `taskTimeout: 0`
+// must override a pool default of, say, 500, whereas simply not mentioning
+// `taskTimeout` should inherit the pool default. A plain `?? `/`||` cannot tell
+// those two cases apart, so callers must pass the presence flags.
+
+import { parseGracePeriod, parseTaskTimeout } from './options'
+
+export interface DeadlineConfigInput {
+  taskTimeout?: unknown
+  gracePeriod?: unknown
+  hasTaskTimeout: boolean
+  hasGracePeriod: boolean
+}
+
+export interface ResolvedDeadline {
+  taskTimeout: number | undefined
+  gracePeriod: number
+}
+
+export function resolveDeadline(
+  perCall: DeadlineConfigInput,
+  poolDefaults: { taskTimeout?: unknown; gracePeriod?: unknown }
+): ResolvedDeadline {
+  const taskTimeout = perCall.hasTaskTimeout
+    ? parseTaskTimeout(perCall.taskTimeout)
+    : parseTaskTimeout(poolDefaults.taskTimeout)
+
+  const gracePeriod = perCall.hasGracePeriod
+    ? parseGracePeriod(perCall.gracePeriod)
+    : parseGracePeriod(poolDefaults.gracePeriod)
+
+  return { taskTimeout, gracePeriod }
+}
diff --git a/src/deadline/scheduler.ts b/src/deadline/scheduler.ts
new file mode 100644
index 0000000..1fca082
--- /dev/null
+++ b/src/deadline/scheduler.ts
@@ -0,0 +1,189 @@
+// The timing engine for per-task deadlines. It owns the two timers behind a
+// deadline (the initial timeout and the optional grace window) and drives the
+// phase transitions: fire -> (grace) -> hard-terminate. It deliberately knows
+// nothing about how a pool is built; everything pool-specific (settling a task,
+// running a teardown, killing a worker) is reached through the `DeadlineHost`
+// hooks, so this file has no dependency on the main pool module.
+//
+// Timer note: both timers are `unref()`-ed and every fire path re-checks that
+// the task is still assigned to the worker. A task that finishes normally is
+// simply removed from the worker, so a later-firing timer becomes a no-op — no
+// explicit disarm is required on the happy path.
+
+import { DeadlineMetrics } from './metrics'
+import { TaskTimeoutError } from './errors'
+import {
+  TinypoolEvent,
+  buildGracePayload,
+  buildTerminationPayload,
+  buildTimeoutPayload,
+} from './events'
+
+// A task as seen by the scheduler. The concrete TaskInfo in the pool module
+// structurally satisfies this; the timer/error fields are written back onto it
+// so other pool code (e.g. a worker 'exit' handler) can read the pending error.
+export interface SchedulableTask {
+  taskId: number
+  taskTimeout: number | undefined
+  gracePeriod: number | undefined
+  deadlineTimer: NodeJS.Timeout | null
+  graceTimer: NodeJS.Timeout | null
+  pendingDeadlineError: TaskTimeoutError | null
+}
+
+export interface SchedulableWorker {
+  workerId: number
+}
+
+export interface DeadlineHost {
+  readonly terminateTimeout: number | undefined
+  // Is `taskId` still assigned to this worker (i.e. not yet settled)?
+  hasTask(worker: SchedulableWorker, taskId: number): boolean
+  emit(name: string, payload: unknown): void
+  // Remove the worker from the pool's active set and return its remaining
+  // (sibling) tasks, excluding the timed-out one, having cleared them from the
+  // worker. These siblings will be failed with the termination error.
+  detachWorker(worker: SchedulableWorker, timedOutTaskId: number): SchedulableTask[]
+  // Run the worker's teardown hook. Returns null when no teardown is configured.
+  postTeardown(worker: SchedulableWorker): Promise<void> | null
+  // Settle a task's promise with `error`.
+  settle(task: SchedulableTask, error: unknown): void
+  // The error used to fail sibling tasks of a terminated worker.
+  terminationError(): unknown
+  // Tear down the underlying worker thread/process.
+  killWorker(worker: SchedulableWorker): void
+  ensureMinimumWorkers(): void
+}
+
+export class DeadlineScheduler {
+  constructor(
+    private readonly host: DeadlineHost,
+    readonly metrics: DeadlineMetrics
+  ) {}
+
+  // Start the deadline for a task that has just been posted to a worker. No-op
+  // when the task has no (or a disabled) timeout — by this point taskTimeout is
+  // already normalized to a positive finite number or undefined.
+  arm(task: SchedulableTask, worker: SchedulableWorker): void {
+    const timeout = task.taskTimeout
+    if (timeout == null) return
+    const grace = task.gracePeriod ?? 0
+
+    task.deadlineTimer = setTimeout(() => {
+      task.deadlineTimer = null
+      if (!this.host.hasTask(worker, task.taskId)) return
+
+      this.metrics.recordTimeout()
+      this.host.emit(
+        TinypoolEvent.TaskTimeout,
+        buildTimeoutPayload(task.taskId, worker.workerId, timeout, grace)
+      )
+
+      if (grace <= 0) {
+        void this.hardTerminate(task, worker, timeout, grace, false)
+        return
+      }
+
+      this.metrics.recordGraceEntry()
+      this.host.emit(
+        TinypoolEvent.TaskTimeoutGrace,
+        buildGracePayload(task.taskId, worker.workerId, timeout, grace)
+      )
+      task.pendingDeadlineError = new TaskTimeoutError({
+        taskTimeout: timeout,
+        gracePeriod: grace,
+        graceEntered: true,
+        teardownAttempted: false,
+        teardownCompleted: false,
+      })
+
+      task.graceTimer = setTimeout(() => {
+        task.graceTimer = null
+        if (!this.host.hasTask(worker, task.taskId)) return
+        void this.hardTerminate(task, worker, timeout, grace, true)
+      }, grace).unref()
+    }, timeout).unref()
+  }
+
+  private clearTimers(task: SchedulableTask): void {
+    if (task.deadlineTimer !== null) {
+      clearTimeout(task.deadlineTimer)
+      task.deadlineTimer = null
+    }
+    if (task.graceTimer !== null) {
+      clearTimeout(task.graceTimer)
+      task.graceTimer = null
+    }
+  }
+
+  private rejectAfter(ms: number): Promise<never> {
+    return new Promise<never>((_, reject) =>
+      setTimeout(() => reject(new Error('Teardown timed out')), ms).unref()
+    )
+  }
+
+  async hardTerminate(
+    task: SchedulableTask,
+    worker: SchedulableWorker,
+    taskTimeout: number,
+    gracePeriod: number,
+    graceEntered: boolean
+  ): Promise<void> {
+    this.clearTimers(task)
+
+    const siblings = this.host.detachWorker(worker, task.taskId)
+    this.metrics.recordTermination()
+
+    let teardownAttempted = false
+    let teardownCompleted = false
+    const teardownPromise = this.host.postTeardown(worker)
+    if (teardownPromise !== null) {
+      teardownAttempted = true
+      try {
+        const budget = this.host.terminateTimeout
+        if (budget != null && budget > 0) {
+          await Promise.race([teardownPromise, this.rejectAfter(budget)])
+        } else {
+          await teardownPromise
+        }
+        teardownCompleted = true
+      } catch (err) {
+        // A teardown that throws or overruns its budget is reported on the
+        // pool's 'error' channel; it must not block the caller's rejection.
+        this.host.emit('error', err)
+      }
+    }
+
+    this.host.emit(
+      TinypoolEvent.TaskTimeoutTermination,
+      buildTerminationPayload(
+        task.taskId,
+        worker.workerId,
+        taskTimeout,
+        gracePeriod,
+        graceEntered,
+        teardownAttempted,
+        teardownCompleted
+      )
+    )
+
+    this.host.settle(
+      task,
+      new TaskTimeoutError({
+        taskTimeout,
+        gracePeriod,
+        graceEntered,
+        teardownAttempted,
+        teardownCompleted,
+      })
+    )
+
+    const terminationError = this.host.terminationError()
+    for (const sibling of siblings) {
+      this.host.settle(sibling, terminationError)
+    }
+
+    this.host.killWorker(worker)
+    this.host.ensureMinimumWorkers()
+  }
+}
